# ─── Hugging Face ────────────────────────────────────────────
# Required to download Gemma models.
# 1. Create account: https://huggingface.co
# 2. Accept Gemma license: https://huggingface.co/google/gemma-3-4b-it
# 3. Generate token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# GGUF model repos (override to use community repacks like bartowski)
GGUF_LOGIC_REPO=google/gemma-3-4b-it-qat-q4_0-gguf
GGUF_LOGIC_FILE=gemma-3-4b-it-q4_0.gguf

GGUF_VISION_REPO=google/gemma-3-4b-it-qat-q4_0-gguf
GGUF_VISION_FILE=gemma-3-4b-it-q4_0.gguf

# ─── llama.cpp server ────────────────────────────────────────
LLAMA_MODEL=gemma-3-4b-it-q4_0.gguf
LLAMA_CTX_SIZE=4096
LLAMA_GPU_LAYERS=0       # Set >0 if you have a GPU (e.g. 20 for partial offload)
LLAMA_THREADS=4          # Match your CPU core count

# ─── Backend ─────────────────────────────────────────────────
LLAMA_SERVER_URL=http://llama-server:8080
VAULT_PATH=/vault
FASTSD_URL=http://fastsd:7860

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
