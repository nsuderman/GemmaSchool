# ─── Ollama ──────────────────────────────────────────────────
# Ollama runs as a Docker service — no account or token required.
# Use the setup wizard on first run to pull a model automatically.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b

# ─── Backend ─────────────────────────────────────────────────
VAULT_PATH=/vault
FASTSD_URL=http://fastsd:7860

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
