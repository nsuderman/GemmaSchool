# ─── llama.cpp ────────────────────────────────────────────────
# llama.cpp server runs as a Docker service.
# Setup wizard downloads a GGUF model into ./models.
LLAMA_BASE_URL=http://llama-server:8080
LLAMA_MODEL=gemma4:e2b
LLAMA_MODEL_FILE=gemma-4-E2B-it-Q4_K_M.gguf
LLAMA_CTX_SIZE=12288
LLAMA_BATCH_SIZE=1024
CHRONOS_STABLE_TOOLING=0

# ─── Backend ─────────────────────────────────────────────────
VAULT_PATH=/vault
FASTSD_URL=http://fastsd:7860

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
